{
  "tools": [
    {
      "id": "gpu-dashboard",
      "title": "GPU Dashboard",
      "description": "Windows 端直接启动本地 GPU Dashboard；Linux 端启动 /home/jk/gpu-dashboard/start.sh，然后打开本地 GPU 控制台。",
      "kind": "web",
      "url": "http://127.0.0.1:8765/",
      "port": 8765,
      "openDelaySeconds": 4,
      "tags": [
        "Local Web",
        "GPU",
        "Port 8765"
      ],
      "launch": {
        "linux": {
          "command": [
            "./start.sh"
          ],
          "cwd": "/home/jk/gpu-dashboard"
        }
      }
    },
    {
      "id": "textstreampro-web",
      "title": "TextStreamPro Web",
      "description": "网页版文本规则流，读取 myapp/replacer_profiles.json，支持配置方案、规则替换和 Markdown 批量处理。",
      "kind": "web",
      "url": "http://127.0.0.1:3939/tools/textstreampro/",
      "tags": [
        "Local Web",
        "Text",
        "Rules"
      ]
    },
    {
      "id": "convert-title-web",
      "title": "convert_title Web",
      "description": "网页版标题转换工具，保留非法字符清理、虚词小写和标题大小写转换。",
      "kind": "web",
      "url": "http://127.0.0.1:3939/tools/convert-title/",
      "tags": [
        "Local Web",
        "Title",
        "Text"
      ]
    },
    {
      "id": "tex-diff-web",
      "title": "tex_diff Web",
      "description": "网页版 TeX 智能文本比对，按空白 token 拆分并区分内容变化与空白变化。",
      "kind": "web",
      "url": "http://127.0.0.1:3939/tools/tex-diff/",
      "tags": [
        "Local Web",
        "TeX",
        "Diff"
      ]
    },
    {
      "id": "overleaf-local-8080",
      "title": "Overleaf Local",
      "description": "Linux 端启动 /home/jk/overleaf/overleaf-toolkit；Windows 端先打开 Start-Overleaf-Tunnel-Key.cmd。两边会打开各自可用的本地地址。",
      "kind": "web",
      "urls": {
        "linux": "http://127.0.0.1/",
        "windows": "http://127.0.0.1:8080/"
      },
      "openDelaySeconds": 6,
      "tags": [
        "Local Web",
        "Overleaf",
        "Port 80",
        "Port 8080"
      ],
      "backend": {
        "windows": {
          "path": "windows-launchers\\Start-Overleaf-Local.cmd",
          "env": {}
        }
      },
      "pathOptions": [
        {
          "label": "选择 Overleaf 启动脚本",
          "kind": "file",
          "target": "backend.windows.env.OVERLEAF_TUNNEL_CMD"
        }
      ],
      "launch": {
        "linux": {
          "command": [
            "bin/up",
            "-d"
          ],
          "cwd": "/home/jk/overleaf/overleaf-toolkit"
        }
      }
    }
  ]
}
