{
  "tools": [
    {
      "id": "gpu-dashboard",
      "title": "GPU Dashboard",
      "description": "Linux/WSL 端启动 /home/jk/gpu-dashboard/start.sh，然后打开本地 GPU 控制台。",
      "kind": "web",
      "url": "http://127.0.0.1:8765/",
      "port": 8765,
      "openDelaySeconds": 4,
      "tags": [
        "Local Web",
        "GPU",
        "Port 8765"
      ],
      "launch": {
        "windows": {
          "command": [
            "wsl.exe",
            "bash",
            "-lc",
            "cd /home/jk/gpu-dashboard && (./stop.sh >/dev/null 2>&1 || true) && HOST=0.0.0.0 PORT=8765 ./start.sh"
          ]
        },
        "linux": {
          "command": [
            "./start.sh"
          ],
          "cwd": "/home/jk/gpu-dashboard"
        }
      }
    },
    {
      "id": "overleaf-local-8080",
      "title": "Overleaf Local",
      "description": "Linux 端启动 /home/jk/overleaf/overleaf-toolkit；Windows 端先打开 Start-Overleaf-Tunnel-Key.cmd。两边会打开各自可用的本地地址。",
      "kind": "web",
      "urls": {
        "linux": "http://127.0.0.1/",
        "windows": "http://127.0.0.1:8080/"
      },
      "openDelaySeconds": 6,
      "tags": [
        "Local Web",
        "Overleaf",
        "Port 80",
        "Port 8080"
      ],
      "launch": {
        "windows": {
          "command": [
            "powershell.exe",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-Command",
            "$src = (wsl.exe wslpath -w /home/jk/overleaf/windows-launcher/Start-Overleaf-Tunnel-Key.cmd).Trim(); $dst = Join-Path $env:TEMP 'Start-Overleaf-Tunnel-Key.cmd'; Copy-Item -LiteralPath $src -Destination $dst -Force; Start-Process -FilePath $dst"
          ]
        },
        "linux": {
          "command": [
            "bin/up",
            "-d"
          ],
          "cwd": "/home/jk/overleaf/overleaf-toolkit"
        }
      }
    }
  ]
}
