---
import { siteConfig } from "../config";

const social = siteConfig.social as Record<string, string | undefined>;
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasMoments = siteConfig.moments && siteConfig.moments.counters.length > 0;
const hasWorkbench = Boolean(siteConfig.localWorkbench);
const hasTimeline = siteConfig.timeline && siteConfig.timeline.length > 0;
const hasPublicProjects = siteConfig.publicProjects && siteConfig.publicProjects.length > 0;
---

<footer class="relative border-t border-gray-200 bg-gray-50">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-col gap-4">
        <h3 class="text-2xl font-bold text-gray-800">
          {siteConfig.name}
        </h3>
        <p class="max-w-xl text-base leading-7 text-gray-600">
          {siteConfig.description}
        </p>

        <div class="flex gap-x-5">
          {
            social.email && (
              <a
                href={`mailto:${social.email}`}
                aria-label="Email"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${siteConfig.accentColor}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
                  <path d="M3 7l9 6l9 -6" />
                </svg>
              </a>
            )
          }
          {
            social.github && (
              <a
                href={social.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${siteConfig.accentColor}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
                </svg>
              </a>
            )
          }
          {
            social.bilibili && (
              <a
                href={social.bilibili}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Bilibili"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${siteConfig.accentColor}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="6" width="18" height="13" rx="3" />
                  <path d="M8 6l-2 -3" />
                  <path d="M16 6l2 -3" />
                  <path d="M10 12v.01" />
                  <path d="M14 12v.01" />
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <div class="hidden flex-col gap-4 md:flex md:items-end">
        <nav class="flex max-w-md flex-wrap justify-end gap-x-6 gap-y-2">
          {
            hasMoments && (
              <a href="#moments" class="text-sm text-gray-600 transition-colors hover:text-gray-800">
                时光
              </a>
            )
          }
          {
            hasWorkbench && (
              <a href="#workbench" class="text-sm text-gray-600 transition-colors hover:text-gray-800">
                本地工具台
              </a>
            )
          }
          <a href="#about" class="text-sm text-gray-600 transition-colors hover:text-gray-800">关于</a>
          <a href="#notes" class="text-sm text-gray-600 transition-colors hover:text-gray-800">笔记</a>
          {
            hasTimeline && (
              <a href="#timeline" class="text-sm text-gray-600 transition-colors hover:text-gray-800">
                时间线
              </a>
            )
          }
          {
            hasPublicProjects && (
              <a href="#public-projects" class="text-sm text-gray-600 transition-colors hover:text-gray-800">
                项目
              </a>
            )
          }
          {
            hasProjects && (
              <a href="#projects" class="text-sm text-gray-600 transition-colors hover:text-gray-800">
                精选资源
              </a>
            )
          }
          <a href="/cv" class="text-sm text-gray-600 transition-colors hover:text-gray-800">CV</a>
          {
            hasExperience && (
              <a href="#experience" class="text-sm text-gray-600 transition-colors hover:text-gray-800">
                经历
              </a>
            )
          }
          {
            hasEducation && (
              <a href="#education" class="text-sm text-gray-600 transition-colors hover:text-gray-800">
                教育
              </a>
            )
          }
        </nav>
        <p class="text-sm text-gray-500">
          © {new Date().getFullYear()} {siteConfig.name}
        </p>
      </div>
    </div>
  </div>
</footer>
