---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasMoments = siteConfig.moments && siteConfig.moments.counters.length > 0;
const hasWorkbench = Boolean(siteConfig.localWorkbench);
const hasTimeline = siteConfig.timeline && siteConfig.timeline.length > 0;
const hasPublicProjects = siteConfig.publicProjects && siteConfig.publicProjects.length > 0;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 hidden md:block transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      {
        hasMoments && (
          <li>
            <a
              href="#moments"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              时光
            </a>
          </li>
        )
      }
      {
        hasWorkbench && (
          <li>
            <a
              href="#workbench"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              本地工具台
            </a>
          </li>
        )
      }
      <li>
        <a
          href="#about"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          关于
        </a>
      </li>
      <li>
        <a
          href="#notes"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          笔记
        </a>
      </li>
      {
        hasTimeline && (
          <li>
            <a
              href="#timeline"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              时间线
            </a>
          </li>
        )
      }
      {
        hasPublicProjects && (
          <li>
            <a
              href="#public-projects"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              项目
            </a>
          </li>
        )
      }
      {
        hasProjects && (
          <li>
            <a
              href="#projects"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              精选资源
            </a>
          </li>
        )
      }
      <li>
        <a
          href="/cv"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          CV
        </a>
      </li>
      {
        hasExperience && (
          <li>
            <a
              href="#experience"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              经历
            </a>
          </li>
        )
      }
      {
        hasEducation && (
          <li>
            <a
              href="#education"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              教育
            </a>
          </li>
        )
      }
    </ul>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 100) {
      header?.classList.add("bg-white/80", "backdrop-blur-sm");
    } else {
      header?.classList.remove("bg-white/80", "backdrop-blur-sm");
    }
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
