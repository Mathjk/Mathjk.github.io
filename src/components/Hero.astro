---
import { siteConfig } from "../config";

const social = siteConfig.social as Record<string, string | undefined>;
const heroNameLines = siteConfig.heroNameLines ?? [siteConfig.name];
---

<div
  id="hero"
  class="relative isolate min-h-[92vh] overflow-hidden bg-white"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(ellipse 900px 900px at 8% 8%, ${siteConfig.accentColor}24 0%, ${siteConfig.accentColor}14 30%, rgba(255,255,255,.72) 64%, white 100%)`}
  >
  </div>

  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(90%_90%_at_top_left,white,transparent)]"
  >
    <defs>
      <pattern
        id="math-symbols"
        x="0"
        y="0"
        width="420"
        height="420"
        patternUnits="userSpaceOnUse"
      >
        <text x="42" y="68" fill={siteConfig.accentColor} font-family="serif" font-size="32" opacity="0.38" transform="rotate(-10)">∫</text>
        <text x="158" y="112" fill={siteConfig.accentColor} font-family="serif" font-size="26" opacity="0.32" transform="rotate(8)">π</text>
        <text x="270" y="84" fill={siteConfig.accentColor} font-family="serif" font-size="30" opacity="0.28" transform="rotate(-6)">∞</text>
        <text x="92" y="220" fill={siteConfig.accentColor} font-family="serif" font-size="28" opacity="0.30" transform="rotate(12)">Σ</text>
        <text x="300" y="218" fill={siteConfig.accentColor} font-family="serif" font-size="25" opacity="0.30" transform="rotate(-12)">dx</text>
        <text x="170" y="330" fill={siteConfig.accentColor} font-family="serif" font-size="29" opacity="0.26" transform="rotate(6)">lim</text>
      </pattern>
      <pattern
        id="fine-grid"
        x="50%"
        y={-1}
        width={180}
        height={180}
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 180V.5H180" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#math-symbols)" width="100%" height="100%"></rect>
    <rect fill="url(#fine-grid)" width="100%" height="100%" stroke-width={0} opacity="0.55"></rect>
  </svg>

  <div class="mx-auto flex min-h-[92vh] max-w-7xl items-center px-8 py-24 sm:px-12 md:px-24">
    <div class="max-w-5xl">
      {
        siteConfig.avatar && (
          <img
            src={siteConfig.avatar}
            alt={siteConfig.name}
            class="mb-10 h-24 w-24 rounded-full border border-gray-200 object-cover shadow-sm sm:h-28 sm:w-28"
          />
        )
      }
      <p class="font-mono text-sm font-semibold uppercase tracking-[0.24em] text-gray-500 animate-fade-in">
        Ciallo. Mathematics and tools.
      </p>
      <h1 class="mt-6 max-w-4xl text-pretty text-4xl font-black leading-tight tracking-tight text-gray-900 animate-fade-in animation-delay-200 sm:text-6xl md:text-7xl lg:text-8xl">
        {heroNameLines.map((line) => <span class="block">{line}</span>)}
      </h1>
      <p class="mt-8 max-w-3xl text-pretty text-lg font-medium leading-8 text-gray-600 animate-fade-in animation-delay-400 sm:text-xl md:text-2xl">
        {siteConfig.title}
      </p>
      <p class="mt-5 max-w-3xl text-base leading-8 text-gray-500 animate-fade-in animation-delay-600 sm:text-lg">
        {siteConfig.description}
      </p>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 flex gap-x-5 px-8 py-10 text-gray-700 animate-fade-in animation-delay-600 sm:px-12 md:px-24">
    {
      social.email && (
        <a
          href={`mailto:${social.email}`}
          aria-label="Email"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
            <path d="M3 7l9 6l9 -6" />
          </svg>
        </a>
      )
    }
    {
      social.github && (
        <a
          href={social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
          </svg>
        </a>
      )
    }
    {
      social.bilibili && (
        <a
          href={social.bilibili}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Bilibili"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="6" width="18" height="13" rx="3" />
            <path d="M8 6l-2 -3" />
            <path d="M16 6l2 -3" />
            <path d="M10 12v.01" />
            <path d="M14 12v.01" />
          </svg>
        </a>
      )
    }
  </div>
</div>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }

  .animation-delay-600 {
    animation-delay: 0.6s;
  }
</style>
