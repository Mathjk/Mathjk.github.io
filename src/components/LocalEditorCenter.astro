---
import { siteConfig } from "../config";

const bridgeUrl = siteConfig.localWorkbench?.bridgeUrl ?? "http://127.0.0.1:3939";
---

<section
  id="editor-center"
  class="p-8 sm:p-12 md:p-16 lg:p-24"
  data-bridge-url={bridgeUrl}
>
  <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-12 lg:gap-16">
    <div class="lg:col-span-4">
      <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl md:text-5xl xl:text-7xl">
        编辑中心
      </h2>
      <div
        class="mt-2 h-[5px] w-[75px] rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      />
      <p class="mt-6 max-w-sm text-base leading-7 text-gray-500">
        {siteConfig.localEditor.note}
      </p>
    </div>

    <div class="lg:col-span-8">
      <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6 md:p-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
              Local Only
            </p>
            <h3 class="mt-2 text-2xl font-bold text-gray-900">本地数据写入状态</h3>
          </div>
          <span id="editorCenterStatus" class="rounded-full bg-gray-100 px-3 py-1.5 font-mono text-xs font-semibold text-gray-600">
            Checking
          </span>
        </div>

        <div id="editorCenterBody" class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2"></div>

        <div id="noteEditorPanel" class="mt-6 hidden rounded-2xl border border-gray-200 bg-gray-50 p-5">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
            Add Note
          </p>
          <h4 class="mt-2 text-xl font-bold text-gray-900">新增 Markdown 笔记</h4>
          <form id="noteForm" class="mt-5 grid grid-cols-1 gap-3">
            <input name="title" required placeholder="标题" class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm outline-none focus:border-gray-400" />
            <input name="summary" placeholder="摘要" class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm outline-none focus:border-gray-400" />
            <input name="tags" placeholder="标签，用逗号分隔" class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm outline-none focus:border-gray-400" />
            <textarea name="body" rows="5" placeholder="正文 Markdown" class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm outline-none focus:border-gray-400"></textarea>
            <button type="submit" class="justify-self-start rounded-lg bg-gray-900 px-4 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">
              保存笔记
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const editorCenter = document.getElementById("editor-center");
  const editorCenterStatus = document.getElementById("editorCenterStatus");
  const editorCenterBody = document.getElementById("editorCenterBody");
  const noteEditorPanel = document.getElementById("noteEditorPanel");
  const noteForm = document.getElementById("noteForm");
  const editorBridgeUrl = editorCenter?.dataset.bridgeUrl || "http://127.0.0.1:3939";
  const editorTokenKey = "myweb.editorToken";

  function setCenterStatus(label, ok = false) {
    if (!editorCenterStatus) return;
    editorCenterStatus.textContent = label;
    editorCenterStatus.className = `rounded-full px-3 py-1.5 font-mono text-xs font-semibold ${ok ? "bg-emerald-50 text-emerald-700" : "bg-amber-50 text-amber-700"}`;
  }

  async function centerRequest(path) {
    const headers = new Headers();
    const token = localStorage.getItem(editorTokenKey);
    if (token) headers.set("X-MyWeb-Token", token);
    const response = await fetch(`${editorBridgeUrl}${path}`, { headers });
    const data = await response.json();
    if (!response.ok || !data.ok) throw new Error(data.error || `HTTP ${response.status}`);
    return data;
  }

  async function centerPost(path, payload) {
    const headers = new Headers({ "Content-Type": "application/json" });
    const token = localStorage.getItem(editorTokenKey);
    if (token) headers.set("X-MyWeb-Token", token);
    const response = await fetch(`${editorBridgeUrl}${path}`, {
      method: "POST",
      headers,
      body: JSON.stringify(payload),
    });
    const data = await response.json();
    if (!response.ok || !data.ok) throw new Error(data.error || `HTTP ${response.status}`);
    return data;
  }

  async function loadEditorCenter() {
    try {
      const state = await centerRequest("/api/editor/state");
      const resources = await centerRequest("/api/editor/resources");
      const tools = await centerRequest("/api/tools");
      setCenterStatus(state.authenticated ? "Unlocked" : "Read Only", state.authenticated);
      noteEditorPanel?.classList.toggle("hidden", !state.authenticated);
      if (editorCenterBody) {
        editorCenterBody.innerHTML = [
          ["资源 JSON", state.resourcesPath, `${resources.resources?.length || 0} 组资源`],
          ["工具 JSON", state.toolsPath, `${tools.tools?.length || 0} 个工具`],
          ["笔记目录", state.notesPath || "devportfolio/src/content/notes", "Markdown 笔记"],
          ["发布模式", "GitHub Pages", "外部访问只读"],
        ].map(([title, path, detail]) => `
          <div class="rounded-2xl border border-gray-200 bg-gray-50 p-4">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">${title}</p>
            <p class="mt-3 break-all font-mono text-xs text-gray-600">${path}</p>
            <p class="mt-3 text-sm text-gray-700">${detail}</p>
          </div>
        `).join("");
      }
    } catch (error) {
      setCenterStatus("Offline", false);
      noteEditorPanel?.classList.add("hidden");
      if (editorCenterBody) {
        editorCenterBody.innerHTML = `
          <div class="rounded-2xl border border-dashed border-gray-300 bg-gray-50 p-5 sm:col-span-2">
            <h4 class="text-lg font-bold text-gray-900">编辑中心离线</h4>
            <p class="mt-3 text-sm leading-7 text-gray-600">启动本地桥接服务后，这里会显示可写入的数据文件和编辑状态。线上访问保持只读。</p>
          </div>
        `;
      }
    }
  }

  noteForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = new FormData(noteForm);
    try {
      await centerPost("/api/editor/notes", {
        title: String(form.get("title") || "").trim(),
        summary: String(form.get("summary") || "").trim(),
        tags: String(form.get("tags") || "").trim(),
        body: String(form.get("body") || "").trim(),
      });
      noteForm.reset();
      await loadEditorCenter();
      alert("笔记已保存。重新构建后会出现在 /notes。");
    } catch (error) {
      alert(`保存笔记失败：${error.message}`);
    }
  });

  loadEditorCenter();
  window.addEventListener("myweb-token-updated", loadEditorCenter);
</script>
