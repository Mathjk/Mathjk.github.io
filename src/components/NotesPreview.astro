---
import { siteConfig } from "../config";

const noteModules = import.meta.glob("../content/notes/*.md", { eager: true });
const notes = Object.entries(noteModules)
  .map(([path, module]) => {
    const mod = module as { frontmatter?: Record<string, unknown> };
    const slug = path.split("/").pop()?.replace(/\.md$/, "") ?? "";
    return {
      slug,
      title: String(mod.frontmatter?.title ?? slug),
      date: String(mod.frontmatter?.date ?? ""),
      summary: String(mod.frontmatter?.summary ?? ""),
      tags: Array.isArray(mod.frontmatter?.tags) ? mod.frontmatter?.tags as string[] : [],
    };
  })
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 3);
---

{
  notes.length > 0 && (
    <section id="notes" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-4">
          <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl md:text-5xl xl:text-7xl">
            {siteConfig.notes.title}
          </h2>
          <div
            class="mt-2 h-[5px] w-[75px] rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
          <p class="mt-6 max-w-sm text-base leading-7 text-gray-500">
            {siteConfig.notes.description}
          </p>
          <a href="/notes" class="mt-6 inline-flex rounded-lg bg-gray-900 px-4 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">
            查看全部
          </a>
        </div>

        <div class="lg:col-span-8">
          <div class="space-y-7">
            {notes.map((note, index) => (
              <a href={`/notes/${note.slug}`} class="group block rounded-2xl border border-gray-200 bg-gray-50 p-5 transition-all duration-300 hover:-translate-y-1 hover:border-gray-300 hover:bg-white hover:shadow-xl sm:p-6 md:p-8">
                <span class="font-mono text-sm" style={{ color: siteConfig.accentColor }}>
                  {String(index + 1).padStart(2, "0")}
                </span>
                <h3 class="mt-2 text-xl font-bold text-gray-900 sm:text-2xl">
                  {note.title}
                </h3>
                <p class="mt-3 text-base leading-relaxed text-gray-600">
                  {note.summary}
                </p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {note.date && <span class="rounded-md bg-white px-2.5 py-1 font-mono text-xs text-gray-600 ring-1 ring-gray-200">{note.date}</span>}
                  {note.tags.map((tag) => (
                    <span class="rounded-md bg-gray-900 px-2.5 py-1 font-mono text-xs font-medium text-white">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}
