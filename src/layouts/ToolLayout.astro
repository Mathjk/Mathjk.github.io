---
import ThemeToggle from "../components/ThemeToggle.astro";
import { siteConfig } from "../config";
import "../styles/global.css";

const { title, subtitle, eyebrow = "Local Web Tool" } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={subtitle} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Noto+Serif+SC:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("myweb.theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        if ((saved || preferred) === "dark") document.documentElement.classList.add("theme-dark");
      })();
    </script>
    <title>{title} - {siteConfig.name}</title>
  </head>
  <body>
    <main class="min-h-screen bg-white">
      <section class="border-b border-gray-200 bg-gray-50 px-6 py-6 sm:px-10">
        <div class="mx-auto flex max-w-7xl flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <a href="/" class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
              ← Home
            </a>
            <p class="mt-8 font-mono text-xs font-semibold uppercase tracking-[0.22em] text-blue-600">{eyebrow}</p>
            <h1 class="mt-3 text-4xl font-black tracking-tight text-gray-900 sm:text-6xl">{title}</h1>
            <p class="mt-5 max-w-3xl text-base leading-8 text-gray-600 sm:text-lg">{subtitle}</p>
          </div>
          <div class="rounded-2xl border border-gray-200 bg-white p-4">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Status</p>
            <p id="toolBridgeStatus" class="mt-2 font-mono text-xs font-semibold text-amber-700">Checking</p>
          </div>
        </div>
      </section>
      <section class="px-6 py-8 sm:px-10 lg:py-12">
        <div class="mx-auto max-w-7xl">
          <slot />
        </div>
      </section>
    </main>
    <ThemeToggle />
  </body>
</html>
