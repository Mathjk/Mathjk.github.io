---
import defaultStopWords from "../../../data/convert-title-stop-words.json";
import ToolLayout from "../../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="convert_title"
  subtitle="标题转换、非法字符清理和虚词大小写配置。默认规则随 GitHub 页面发布，使用时不需要本地桥接或 token。"
  eyebrow="Text Utility"
>
  <div id="convertTitleApp" class="grid grid-cols-1 gap-6 lg:grid-cols-12">
    <aside class="lg:col-span-4">
      <div class="rounded-2xl border border-gray-200 bg-white p-5">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Stop Words</p>
        <textarea
          id="stopWords"
          rows="14"
          class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 font-mono text-xs leading-6 text-gray-700 outline-none focus:border-gray-400"
        ></textarea>
        <div class="mt-3 flex flex-wrap gap-2">
          <button id="saveStopWords" type="button" class="rounded-lg bg-gray-900 px-3 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">保存到浏览器</button>
          <button id="resetStopWords" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">恢复默认</button>
        </div>
      </div>
    </aside>

    <section class="lg:col-span-8">
      <div class="grid grid-cols-1 gap-5">
        <div class="rounded-2xl border border-gray-200 bg-white p-5">
          <div class="flex items-center justify-between gap-3">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Input</p>
            <button id="convertClipboard" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">粘贴</button>
          </div>
          <textarea
            id="titleInput"
            rows="8"
            class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-base leading-7 text-gray-800 outline-none focus:border-gray-400"
            placeholder='An example: title / with invalid chars?'
          ></textarea>
          <button id="convertRun" type="button" class="mt-4 rounded-lg bg-gray-900 px-4 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">转换</button>
        </div>

        <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
          <div class="flex items-center justify-between gap-3">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Output</p>
            <button id="copyOutput" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">复制</button>
          </div>
          <pre id="titleOutput" class="mt-4 min-h-32 whitespace-pre-wrap rounded-lg bg-white p-4 font-mono text-sm leading-7 text-gray-800 ring-1 ring-gray-200"></pre>
        </div>
      </div>
    </section>
  </div>

  <script id="defaultStopWordsSeed" type="application/json" set:html={JSON.stringify(defaultStopWords)} />

  <script>
    const statusNode = document.getElementById("toolBridgeStatus");
    const stopWordsNode = document.getElementById("stopWords");
    const inputNode = document.getElementById("titleInput");
    const outputNode = document.getElementById("titleOutput");
    const stopWordsKey = "myweb.convertTitle.stopWords";
    const defaultStopWords = JSON.parse(document.getElementById("defaultStopWordsSeed")?.textContent || "[]");

    function setStatus(text, ok = true) {
      if (!statusNode) return;
      statusNode.textContent = text;
      statusNode.className = `mt-2 font-mono text-xs font-semibold ${ok ? "text-emerald-700" : "text-amber-700"}`;
    }

    function getStopWords() {
      return (stopWordsNode?.value || "").split(/\s+/).map((word) => word.trim().toLowerCase()).filter(Boolean);
    }

    function setStopWords(words) {
      if (stopWordsNode) stopWordsNode.value = [...new Set(words)].sort().join("\n");
    }

    function loadStopWords() {
      const saved = localStorage.getItem(stopWordsKey);
      setStopWords(saved ? JSON.parse(saved) : defaultStopWords);
      setStatus("Ready");
    }

    function convertTitle(text, stopWords) {
      const cleanText = String(text || "").replace(/\n/g, " ").replace(/\r/g, "").replace(/[\\/:*?"<>|]/g, "");
      const cleaned = cleanText.split(/\s+/).filter(Boolean).join(" ");
      const stopWordSet = new Set(stopWords);
      const words = cleaned.split(/\s+/).filter(Boolean);
      return words.map((word, index) => {
        const lower = word.toLowerCase();
        const isEdge = index === 0 || index === words.length - 1;
        return isEdge || !stopWordSet.has(lower) ? lower.charAt(0).toUpperCase() + lower.slice(1) : lower;
      }).join(" ");
    }

    document.getElementById("saveStopWords")?.addEventListener("click", () => {
      localStorage.setItem(stopWordsKey, JSON.stringify(getStopWords()));
      setStatus("Saved");
    });

    document.getElementById("resetStopWords")?.addEventListener("click", () => {
      localStorage.removeItem(stopWordsKey);
      setStopWords(defaultStopWords);
      setStatus("Default");
    });

    document.getElementById("convertRun")?.addEventListener("click", () => {
      if (outputNode) outputNode.textContent = convertTitle(inputNode?.value || "", getStopWords());
    });

    document.getElementById("convertClipboard")?.addEventListener("click", async () => {
      if (inputNode && navigator.clipboard) inputNode.value = await navigator.clipboard.readText();
    });

    document.getElementById("copyOutput")?.addEventListener("click", async () => {
      if (navigator.clipboard) await navigator.clipboard.writeText(outputNode?.textContent || "");
    });

    loadStopWords();
  </script>
</ToolLayout>
