---
import ToolLayout from "../../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="convert_title"
  subtitle="标题转换、非法字符清理和虚词大小写配置。"
  eyebrow="Text Utility"
>
  <div id="convertTitleApp" data-bridge-url="http://127.0.0.1:3939" class="grid grid-cols-1 gap-6 lg:grid-cols-12">
    <aside class="lg:col-span-4">
      <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Local Token</p>
        <input
          id="convertToken"
          type="password"
          autocomplete="off"
          placeholder="本地编辑 token"
          class="mt-4 w-full rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs text-gray-700 outline-none focus:border-gray-400"
        />
        <div class="mt-3 flex gap-2">
          <button id="convertUnlock" type="button" class="rounded-lg bg-gray-900 px-3 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">解锁</button>
          <button id="convertLock" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">锁定</button>
        </div>
      </div>

      <div class="mt-5 rounded-2xl border border-gray-200 bg-white p-5">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Stop Words</p>
        <textarea
          id="stopWords"
          rows="10"
          class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 font-mono text-xs leading-6 text-gray-700 outline-none focus:border-gray-400"
        ></textarea>
        <button id="saveStopWords" type="button" class="mt-3 rounded-lg bg-gray-900 px-3 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">保存配置</button>
      </div>
    </aside>

    <section class="lg:col-span-8">
      <div class="grid grid-cols-1 gap-5">
        <div class="rounded-2xl border border-gray-200 bg-white p-5">
          <div class="flex items-center justify-between gap-3">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Input</p>
            <button id="convertClipboard" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">粘贴</button>
          </div>
          <textarea
            id="titleInput"
            rows="8"
            class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-base leading-7 text-gray-800 outline-none focus:border-gray-400"
            placeholder='An example: title / with invalid chars?'
          ></textarea>
          <button id="convertRun" type="button" class="mt-4 rounded-lg bg-gray-900 px-4 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">转换</button>
        </div>

        <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
          <div class="flex items-center justify-between gap-3">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Output</p>
            <button id="copyOutput" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">复制</button>
          </div>
          <pre id="titleOutput" class="mt-4 min-h-32 whitespace-pre-wrap rounded-lg bg-white p-4 font-mono text-sm leading-7 text-gray-800 ring-1 ring-gray-200"></pre>
        </div>
      </div>
    </section>
  </div>

  <script>
    const root = document.getElementById("convertTitleApp");
    const bridgeUrl = root?.dataset.bridgeUrl || "http://127.0.0.1:3939";
    const tokenKey = "myweb.editorToken";
    const statusNode = document.getElementById("toolBridgeStatus");
    const tokenInput = document.getElementById("convertToken");
    const stopWordsNode = document.getElementById("stopWords");
    const inputNode = document.getElementById("titleInput");
    const outputNode = document.getElementById("titleOutput");

    function token() {
      return localStorage.getItem(tokenKey) || "";
    }

    function setStatus(text, ok = false) {
      if (!statusNode) return;
      statusNode.textContent = text;
      statusNode.className = `mt-2 font-mono text-xs font-semibold ${ok ? "text-emerald-700" : "text-amber-700"}`;
    }

    async function request(path, options = {}) {
      const headers = new Headers(options.headers || {});
      if (token()) headers.set("X-MyWeb-Token", token());
      if (options.body && !headers.has("Content-Type")) headers.set("Content-Type", "application/json");
      const response = await fetch(`${bridgeUrl}${path}`, { ...options, headers });
      const data = await response.json();
      if (!response.ok || !data.ok) throw new Error(data.error || `HTTP ${response.status}`);
      return data;
    }

    async function loadConfig() {
      if (tokenInput) tokenInput.value = token();
      try {
        const data = await request("/api/web-tools/convert-title/config");
        if (stopWordsNode) stopWordsNode.value = (data.config.stop_words || []).join("\n");
        setStatus("Unlocked", true);
      } catch {
        setStatus("Locked");
      }
    }

    document.getElementById("convertUnlock")?.addEventListener("click", async () => {
      localStorage.setItem(tokenKey, tokenInput?.value?.trim() || "");
      await loadConfig();
    });

    document.getElementById("convertLock")?.addEventListener("click", async () => {
      localStorage.removeItem(tokenKey);
      if (tokenInput) tokenInput.value = "";
      setStatus("Locked");
    });

    document.getElementById("saveStopWords")?.addEventListener("click", async () => {
      const stopWords = (stopWordsNode?.value || "").split(/\s+/).filter(Boolean);
      await request("/api/web-tools/convert-title/config", {
        method: "POST",
        body: JSON.stringify({ stop_words: stopWords }),
      });
      await loadConfig();
    });

    document.getElementById("convertRun")?.addEventListener("click", async () => {
      const stopWords = (stopWordsNode?.value || "").split(/\s+/).filter(Boolean);
      const data = await request("/api/web-tools/convert-title/process", {
        method: "POST",
        body: JSON.stringify({ text: inputNode?.value || "", stopWords }),
      });
      if (outputNode) outputNode.textContent = data.result.output || "";
    });

    document.getElementById("convertClipboard")?.addEventListener("click", async () => {
      if (inputNode && navigator.clipboard) inputNode.value = await navigator.clipboard.readText();
    });

    document.getElementById("copyOutput")?.addEventListener("click", async () => {
      if (navigator.clipboard) await navigator.clipboard.writeText(outputNode?.textContent || "");
    });

    loadConfig();
  </script>
</ToolLayout>
