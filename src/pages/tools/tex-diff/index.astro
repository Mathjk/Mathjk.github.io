---
import ToolLayout from "../../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="tex_diff"
  subtitle="TeX 文本差异比对，保留原工具的内容变化与空白变化分类。默认在浏览器内完成，不需要本地桥接或 token。"
  eyebrow="TeX Utility"
>
  <div id="texDiffApp" class="space-y-6">
    <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
      <section class="rounded-2xl border border-gray-200 bg-white p-5">
        <div class="flex items-center justify-between">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Original</p>
          <button data-paste-target="originalText" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">粘贴</button>
        </div>
        <textarea
          id="originalText"
          rows="16"
          class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 font-mono text-sm leading-6 text-gray-800 outline-none focus:border-gray-400"
        ></textarea>
      </section>

      <section class="rounded-2xl border border-gray-200 bg-white p-5">
        <div class="flex items-center justify-between">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Modified</p>
          <button data-paste-target="modifiedText" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">粘贴</button>
        </div>
        <textarea
          id="modifiedText"
          rows="16"
          class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 font-mono text-sm leading-6 text-gray-800 outline-none focus:border-gray-400"
        ></textarea>
      </section>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="runDiff" type="button" class="rounded-lg bg-gray-900 px-4 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">开始比对</button>
      <button id="clearDiff" type="button" class="rounded-lg border border-gray-200 bg-white px-4 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">清空</button>
    </div>

    <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
      <section class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Original Diff</p>
        <pre id="leftResult" class="mt-4 min-h-72 overflow-auto whitespace-pre-wrap rounded-lg bg-white p-4 font-mono text-sm leading-6 text-gray-800 ring-1 ring-gray-200"></pre>
      </section>
      <section class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Modified Diff</p>
        <pre id="rightResult" class="mt-4 min-h-72 overflow-auto whitespace-pre-wrap rounded-lg bg-white p-4 font-mono text-sm leading-6 text-gray-800 ring-1 ring-gray-200"></pre>
      </section>
    </div>
  </div>

  <style>
    .diff-del-essential {
      background: #ffcccc;
      text-decoration: line-through;
    }

    .diff-ins-essential {
      background: #ff9999;
    }

    .diff-del-non-essential,
    .diff-ins-non-essential {
      background: #ffffb3;
    }
  </style>

  <script>
    const statusNode = document.getElementById("toolBridgeStatus");
    const originalNode = document.getElementById("originalText");
    const modifiedNode = document.getElementById("modifiedText");
    const leftResult = document.getElementById("leftResult");
    const rightResult = document.getElementById("rightResult");

    function setStatus(text, ok = true) {
      if (!statusNode) return;
      statusNode.textContent = text;
      statusNode.className = `mt-2 font-mono text-xs font-semibold ${ok ? "text-emerald-700" : "text-amber-700"}`;
    }

    function tokenize(text) {
      return String(text || "").split(/(\s+)/).filter(Boolean);
    }

    function commonPrefix(left, right) {
      let index = 0;
      while (index < left.length && index < right.length && left[index] === right[index]) index += 1;
      return index;
    }

    function commonSuffix(left, right, prefixLength) {
      let count = 0;
      while (
        count < left.length - prefixLength &&
        count < right.length - prefixLength &&
        left[left.length - 1 - count] === right[right.length - 1 - count]
      ) {
        count += 1;
      }
      return count;
    }

    function diffSegments(original, modified) {
      const left = tokenize(original);
      const right = tokenize(modified);
      const prefix = commonPrefix(left, right);
      const suffix = commonSuffix(left, right, prefix);
      const leftSegments = [];
      const rightSegments = [];

      const pushEqual = (target, tokens) => {
        if (tokens.length) target.push({ text: tokens.join(""), tag: "equal" });
      };
      const pushChanged = (target, tokens, tag) => {
        if (tokens.length) target.push({ text: tokens.join(""), tag: tokens.join("").trim() ? tag : tag.replace("essential", "non_essential") });
      };

      pushEqual(leftSegments, left.slice(0, prefix));
      pushEqual(rightSegments, right.slice(0, prefix));
      pushChanged(leftSegments, left.slice(prefix, left.length - suffix), "del_essential");
      pushChanged(rightSegments, right.slice(prefix, right.length - suffix), "ins_essential");
      pushEqual(leftSegments, suffix ? left.slice(left.length - suffix) : []);
      pushEqual(rightSegments, suffix ? right.slice(right.length - suffix) : []);
      return { left: leftSegments, right: rightSegments };
    }

    function renderSegments(target, segments) {
      if (!target) return;
      target.textContent = "";
      for (const segment of segments || []) {
        const span = document.createElement("span");
        span.textContent = segment.text || "";
        if (segment.tag && segment.tag !== "equal") {
          span.className = `diff-${String(segment.tag).replaceAll("_", "-")}`;
        }
        target.appendChild(span);
      }
    }

    document.getElementById("runDiff")?.addEventListener("click", () => {
      const result = diffSegments(originalNode?.value || "", modifiedNode?.value || "");
      renderSegments(leftResult, result.left);
      renderSegments(rightResult, result.right);
      setStatus("Ready");
    });

    document.getElementById("clearDiff")?.addEventListener("click", () => {
      if (originalNode) originalNode.value = "";
      if (modifiedNode) modifiedNode.value = "";
      if (leftResult) leftResult.textContent = "";
      if (rightResult) rightResult.textContent = "";
    });

    document.querySelectorAll("[data-paste-target]").forEach((button) => {
      button.addEventListener("click", async () => {
        const target = document.getElementById(button.getAttribute("data-paste-target") || "");
        if (target && navigator.clipboard) target.value = await navigator.clipboard.readText();
      });
    });

    setStatus("Ready");
  </script>
</ToolLayout>
