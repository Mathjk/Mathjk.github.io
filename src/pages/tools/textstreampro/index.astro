---
import defaultProfiles from "../../../data/textstream-profiles.json";
import ToolLayout from "../../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="TextStreamPro"
  subtitle="文本清洗规则流，默认规则随 GitHub 页面发布。普通文本处理不需要本地桥接或 token。"
  eyebrow="Text Workflow"
>
  <div id="textstreamApp" data-bridge-url="http://127.0.0.1:3939" class="grid grid-cols-1 gap-6 xl:grid-cols-12">
    <aside class="xl:col-span-4">
      <div class="rounded-2xl border border-gray-200 bg-white p-5">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Profiles</p>
        <select id="profileSelect" class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700 outline-none focus:border-gray-400"></select>
        <input
          id="profileName"
          class="mt-3 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700 outline-none focus:border-gray-400"
          placeholder="配置名称"
        />
        <div class="mt-3 grid grid-cols-2 gap-2">
          <button id="newProfile" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">新建</button>
          <button id="deleteProfile" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-rose-200 hover:text-rose-700">删除</button>
          <button id="saveProfilesBrowser" type="button" class="rounded-lg bg-gray-900 px-3 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">保存到浏览器</button>
          <button id="resetProfiles" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">恢复默认</button>
        </div>
      </div>

      <div class="mt-5 rounded-2xl border border-gray-200 bg-white p-5">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Batch Markdown</p>
        <p class="mt-3 text-sm leading-7 text-gray-600">本地文件批处理仍通过 127.0.0.1 桥接执行；这里暂时保留原 token 方式，后续再细化权限设计。</p>
        <input
          id="textstreamToken"
          type="password"
          autocomplete="off"
          placeholder="本地编辑 token"
          class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 font-mono text-xs text-gray-700 outline-none focus:border-gray-400"
        />
        <label class="mt-3 flex items-center gap-2 font-mono text-xs text-gray-600">
          <input id="batchApply" type="checkbox" class="h-4 w-4 rounded border-gray-300" />
          写回文件
        </label>
        <textarea
          id="batchPaths"
          rows="5"
          placeholder="/path/a.md | /path/folder"
          class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 font-mono text-xs leading-6 text-gray-700 outline-none focus:border-gray-400"
        ></textarea>
        <button id="runBatch" type="button" class="mt-3 rounded-lg bg-gray-900 px-3 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">批处理</button>
        <pre id="batchResult" class="mt-4 max-h-48 overflow-auto whitespace-pre-wrap rounded-lg bg-gray-50 p-3 font-mono text-xs leading-6 text-gray-700 ring-1 ring-gray-200"></pre>
      </div>
    </aside>

    <section class="xl:col-span-8">
      <div class="rounded-2xl border border-gray-200 bg-white p-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Rules</p>
          <button id="addRule" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">添加规则</button>
        </div>
        <div id="rulesList" class="mt-4 space-y-3"></div>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-5 lg:grid-cols-2">
        <section class="rounded-2xl border border-gray-200 bg-white p-5">
          <div class="flex items-center justify-between">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Source</p>
            <button id="pasteTextstream" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">粘贴</button>
          </div>
          <textarea id="streamInput" rows="14" class="mt-4 w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-sm leading-7 text-gray-800 outline-none focus:border-gray-400"></textarea>
          <button id="processTextstream" type="button" class="mt-4 rounded-lg bg-gray-900 px-4 py-2 font-mono text-xs font-semibold text-white transition-colors hover:bg-gray-700">处理文本</button>
        </section>

        <section class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
          <div class="flex items-center justify-between">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">Result</p>
            <button id="copyTextstream" type="button" class="rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700 transition-colors hover:border-gray-300">复制</button>
          </div>
          <pre id="streamOutput" class="mt-4 min-h-80 overflow-auto whitespace-pre-wrap rounded-lg bg-white p-4 text-sm leading-7 text-gray-800 ring-1 ring-gray-200"></pre>
          <pre id="streamLogs" class="mt-4 whitespace-pre-wrap rounded-lg bg-gray-100 p-3 font-mono text-xs leading-6 text-gray-600"></pre>
        </section>
      </div>
    </section>
  </div>

  <script id="textstreamProfilesSeed" type="application/json" set:html={JSON.stringify(defaultProfiles)} />

  <script>
    const root = document.getElementById("textstreamApp");
    const bridgeUrl = root?.dataset.bridgeUrl || "http://127.0.0.1:3939";
    const tokenKey = "myweb.editorToken";
    const profileStorageKey = "myweb.textstream.profiles";
    const statusNode = document.getElementById("toolBridgeStatus");
    const tokenInput = document.getElementById("textstreamToken");
    const profileSelect = document.getElementById("profileSelect");
    const profileName = document.getElementById("profileName");
    const rulesList = document.getElementById("rulesList");
    const streamInput = document.getElementById("streamInput");
    const streamOutput = document.getElementById("streamOutput");
    const streamLogs = document.getElementById("streamLogs");
    const batchResult = document.getElementById("batchResult");
    const defaultProfiles = JSON.parse(document.getElementById("textstreamProfilesSeed")?.textContent || "{}");
    let profileData = structuredClone(defaultProfiles);

    function token() {
      return tokenInput?.value?.trim() || localStorage.getItem(tokenKey) || "";
    }

    function setStatus(text, ok = true) {
      if (!statusNode) return;
      statusNode.textContent = text;
      statusNode.className = `mt-2 font-mono text-xs font-semibold ${ok ? "text-emerald-700" : "text-amber-700"}`;
    }

    function escapeHtml(value) {
      return String(value || "").replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[char]);
    }

    function currentProfileId() {
      return profileData.current_id || Object.keys(profileData.profiles)[0] || "default";
    }

    function currentProfile() {
      const id = currentProfileId();
      return profileData.profiles[id] || { name: id, rules: [] };
    }

    function normalizeProfiles(payload) {
      const profiles = payload?.profiles && typeof payload.profiles === "object" ? payload.profiles : {};
      const ids = Object.keys(profiles);
      if (!ids.length) return structuredClone(defaultProfiles);
      const currentId = profiles[payload.current_id] ? payload.current_id : ids[0];
      return { current_id: currentId, profiles };
    }

    function loadProfiles() {
      const saved = localStorage.getItem(profileStorageKey);
      profileData = normalizeProfiles(saved ? JSON.parse(saved) : defaultProfiles);
      if (tokenInput) tokenInput.value = localStorage.getItem(tokenKey) || "";
      renderProfiles();
      setStatus("Ready");
    }

    function renderProfiles() {
      if (!profileSelect) return;
      const ids = Object.keys(profileData.profiles);
      profileSelect.innerHTML = ids.map((id) => {
        const profile = profileData.profiles[id];
        return `<option value="${escapeHtml(id)}" ${id === profileData.current_id ? "selected" : ""}>${escapeHtml(profile.name || id)}</option>`;
      }).join("");
      if (profileName) profileName.value = currentProfile().name || currentProfileId();
      renderRules();
    }

    function renderRules() {
      const profile = currentProfile();
      if (!rulesList) return;
      rulesList.innerHTML = (profile.rules || []).map((rule, index) => `
        <article class="rounded-xl border border-gray-200 bg-gray-50 p-3" data-rule-index="${index}">
          <div class="grid grid-cols-1 gap-2 lg:grid-cols-[auto_1fr_1fr_auto] lg:items-center">
            <label class="flex items-center gap-2 font-mono text-xs text-gray-600">
              <input class="rule-active h-4 w-4 rounded border-gray-300" type="checkbox" ${rule.active ? "checked" : ""} />
              ${String(index + 1).padStart(2, "0")}
            </label>
            <input class="rule-find rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs text-gray-700 outline-none focus:border-gray-400" value="${escapeHtml(rule.find)}" placeholder="find" />
            <input class="rule-replace rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs text-gray-700 outline-none focus:border-gray-400" value="${escapeHtml(rule.replace)}" placeholder="replace" />
            <div class="flex flex-wrap gap-2">
              <label class="flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs text-gray-600">
                <input class="rule-regex h-4 w-4 rounded border-gray-300" type="checkbox" ${rule.use_regex ? "checked" : ""} />
                regex
              </label>
              <button class="rule-up rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700" type="button">↑</button>
              <button class="rule-down rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-gray-700" type="button">↓</button>
              <button class="rule-delete rounded-lg border border-gray-200 bg-white px-3 py-2 font-mono text-xs font-semibold text-rose-700" type="button">删除</button>
            </div>
          </div>
        </article>
      `).join("");
    }

    function syncRulesFromDom() {
      const profile = currentProfile();
      profile.rules = [...document.querySelectorAll("[data-rule-index]")].map((row) => ({
        find: row.querySelector(".rule-find")?.value || "",
        replace: row.querySelector(".rule-replace")?.value || "",
        use_regex: Boolean(row.querySelector(".rule-regex")?.checked),
        active: Boolean(row.querySelector(".rule-active")?.checked),
      }));
      if (profileName) profile.name = profileName.value.trim() || currentProfileId();
    }

    function processText(text, rules) {
      let currentText = String(text || "");
      let count = 0;
      const logs = [];
      if (!currentText) return { output: "", logs: ["文本为空"], applied: 0 };

      for (const [index, rule] of rules.entries()) {
        if (!rule.active || !rule.find) continue;
        try {
          if (rule.use_regex) {
            currentText = currentText.replace(new RegExp(rule.find, "g"), rule.replace);
            count += 1;
          } else if (currentText.includes(rule.find)) {
            currentText = currentText.split(rule.find).join(rule.replace);
            count += 1;
          }
        } catch (error) {
          logs.push(`规则 ${index + 1} 错误: ${error.message}`);
        }
      }
      logs.push(`共应用 ${count} 条规则`);
      return { output: currentText, logs, applied: count };
    }

    async function bridgeRequest(path, options = {}) {
      const headers = new Headers(options.headers || {});
      if (token()) headers.set("X-MyWeb-Token", token());
      if (options.body && !headers.has("Content-Type")) headers.set("Content-Type", "application/json");
      const response = await fetch(`${bridgeUrl}${path}`, { ...options, headers });
      const data = await response.json();
      if (!response.ok || !data.ok) throw new Error(data.error || `HTTP ${response.status}`);
      return data;
    }

    profileSelect?.addEventListener("change", () => {
      syncRulesFromDom();
      profileData.current_id = profileSelect.value;
      renderProfiles();
    });

    document.getElementById("newProfile")?.addEventListener("click", () => {
      syncRulesFromDom();
      const id = `profile_${Date.now().toString(36)}`;
      profileData.profiles[id] = { name: "新配置", rules: [] };
      profileData.current_id = id;
      renderProfiles();
    });

    document.getElementById("deleteProfile")?.addEventListener("click", () => {
      if (Object.keys(profileData.profiles).length <= 1) return;
      delete profileData.profiles[currentProfileId()];
      profileData.current_id = Object.keys(profileData.profiles)[0];
      renderProfiles();
    });

    document.getElementById("saveProfilesBrowser")?.addEventListener("click", () => {
      syncRulesFromDom();
      localStorage.setItem(profileStorageKey, JSON.stringify(profileData));
      setStatus("Saved");
    });

    document.getElementById("resetProfiles")?.addEventListener("click", () => {
      localStorage.removeItem(profileStorageKey);
      profileData = structuredClone(defaultProfiles);
      renderProfiles();
      setStatus("Default");
    });

    document.getElementById("addRule")?.addEventListener("click", () => {
      syncRulesFromDom();
      currentProfile().rules.push({ find: "", replace: "", use_regex: false, active: true });
      renderRules();
    });

    rulesList?.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const row = target.closest("[data-rule-index]");
      if (!row) return;
      syncRulesFromDom();
      const index = Number(row.getAttribute("data-rule-index"));
      const rules = currentProfile().rules;
      if (target.closest(".rule-delete")) rules.splice(index, 1);
      if (target.closest(".rule-up") && index > 0) [rules[index - 1], rules[index]] = [rules[index], rules[index - 1]];
      if (target.closest(".rule-down") && index < rules.length - 1) [rules[index + 1], rules[index]] = [rules[index], rules[index + 1]];
      renderRules();
    });

    document.getElementById("processTextstream")?.addEventListener("click", () => {
      syncRulesFromDom();
      const result = processText(streamInput?.value || "", currentProfile().rules || []);
      if (streamOutput) streamOutput.textContent = result.output || "";
      if (streamLogs) streamLogs.textContent = (result.logs || []).join("\n");
      setStatus("Ready");
    });

    document.getElementById("pasteTextstream")?.addEventListener("click", async () => {
      if (streamInput && navigator.clipboard) streamInput.value = await navigator.clipboard.readText();
    });

    document.getElementById("copyTextstream")?.addEventListener("click", async () => {
      if (navigator.clipboard) await navigator.clipboard.writeText(streamOutput?.textContent || "");
    });

    document.getElementById("runBatch")?.addEventListener("click", async () => {
      syncRulesFromDom();
      try {
        if (tokenInput?.value?.trim()) localStorage.setItem(tokenKey, tokenInput.value.trim());
        const response = await bridgeRequest("/api/web-tools/textstream/batch", {
          method: "POST",
          body: JSON.stringify({
            paths: document.getElementById("batchPaths")?.value || "",
            profileId: currentProfileId(),
            apply: Boolean(document.getElementById("batchApply")?.checked),
          }),
        });
        if (batchResult) batchResult.textContent = JSON.stringify(response.batch, null, 2);
      } catch (error) {
        if (batchResult) batchResult.textContent = `批处理失败：${error.message}`;
      }
    });

    loadProfiles();
  </script>
</ToolLayout>
